# Caddyfile – reverse proxy with automatic TLS for the homepage.
#
# Replace your-domain.example.com with your real domain BEFORE starting.
# Caddy obtains TLS certificates automatically via Let's Encrypt.
#
# If you don't have a domain yet, you can test locally with:
#   tls internal
# (generates a self-signed cert for local testing only).

your-domain.example.com {
    # Reverse proxy to the app container.
    # Caddy automatically sets X-Forwarded-For, X-Forwarded-Proto, and
    # X-Forwarded-Host on upstream requests — no explicit header_up needed.
    # The backend must trust these via APP_TRUSTED_PROXY_CIDRS (the compose
    # file defaults to 172.16.0.0/12, which covers Docker bridge networks).
    reverse_proxy app:8080

    # Encode responses for bandwidth savings.
    encode gzip zstd

    # Response security headers (sent to the browser, NOT to the backend).
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        -Server
    }

    # Log format (optional; Caddy defaults are JSON and fine for production).
    # log {
    #     output stdout
    #     format json
    # }
}
